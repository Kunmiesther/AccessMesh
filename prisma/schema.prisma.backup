generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  role          String // CONSUMER | PROVIDER
  createdAt     DateTime @default(now())

  resources Resource[]
}

model Resource {
  id                   String    @id @default(cuid())
  ownerId              String
  creatorWallet        String    @default("")
  creatorDisplayName   String?
  title                String    @default("")
  name                 String
  category             String    @default("CONTENT")
  type                 String // API | CONTENT | TOOL | DATASET
  resourceCategory     String    @default("")
  resourceType         String    @default("")
  resourceContent      String    @default("")
  description          String
  priceUSDC            Float
  resourceUrl          String    @default("")
  endpoint             String
  coverImage           String?
  tags                 String    @default("[]")
  unlockCount          Int       @default(0)
  isActive             Boolean   @default(true)
  publishTxHash        String?   @unique
  publishFeeUSDC       Float?
  publishedAt          DateTime?
  aiSummary            String?
  aiTopics             String?
  aiCategory           String?
  aiAudience           String?
  aiCollection         String?
  aiPlacement          String?
  aiRelatedResourceIds String?
  aiReasoning          String?
  aiAnalyzedAt         DateTime?
  createdAt            DateTime  @default(now())

  owner          User            @relation(fields: [ownerId], references: [id])
  payments       Payment[]
  purchases      Purchase[]
  activityEvents ActivityEvent[]
  x402AccessLogs X402AccessLog[]
  cctpBridges    CctpBridge[]

  @@index([creatorWallet])
  @@index([createdAt])
  @@index([publishedAt])
}

model Payment {
  id             String   @id @default(cuid())
  resourceId     String
  payerWallet    String
  providerWallet String
  amountUSDC     Float
  txHash         String   @unique
  status         String // PENDING | CONFIRMING | SETTLED | FAILED
  createdAt      DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id])

  @@index([payerWallet])
  @@index([providerWallet])
  @@index([resourceId])
}

model Purchase {
  id            String   @id @default(cuid())
  resourceId    String
  buyerWallet   String
  creatorWallet String
  amountUSDC    Float
  txHash        String   @unique
  createdAt     DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id])

  @@unique([resourceId, buyerWallet])
  @@index([buyerWallet])
  @@index([creatorWallet])
  @@index([resourceId])
  @@index([createdAt])
}

model AccessLog {
  id          String   @id @default(cuid())
  resourceId  String
  payerWallet String
  status      String // BLOCKED | UNLOCKED
  txHash      String?
  createdAt   DateTime @default(now())
}

model ActivityEvent {
  id         String   @id @default(cuid())
  type       String // RESOURCE_PUBLISHED | RESOURCE_UNLOCKED | PROTECTED_RESOURCE_ACCESSED | BRIDGE_STARTED | BRIDGE_COMPLETED | BRIDGE_FAILED
  wallet     String
  resourceId String
  title      String
  txHash     String?
  createdAt  DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id])

  @@index([createdAt])
  @@index([wallet])
  @@index([resourceId])
}

model CctpBridge {
  id                 String   @id @default(cuid())
  resourceId         String
  payerWallet        String
  sourceWallet       String
  sourceChain        String
  sourceChainId      Int
  sourceDomain       Int
  destinationChain   String
  destinationChainId Int
  destinationDomain  Int
  amountUSDC         Float
  feeUSDC            Float?
  totalBurnUSDC      Float?
  sourceTxHash       String?  @unique
  destinationTxHash  String?
  status             String // STARTED | COMPLETED | FAILED
  errorMessage       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id])

  @@index([payerWallet])
  @@index([sourceWallet])
  @@index([resourceId])
  @@index([status])
  @@index([createdAt])
}

model X402AccessLog {
  id         String   @id @default(cuid())
  wallet     String
  resourceId String
  result     String // SUCCESS | FAILED
  createdAt  DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id])

  @@index([wallet])
  @@index([resourceId])
  @@index([createdAt])
}

model Agent {
  id          String   @id @default(cuid())
  ownerWallet String
  name        String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  policy     AgentPolicy?
  executions AgentExecution[]

  @@index([ownerWallet])
  @@index([status])
  @@index([createdAt])
}

model AgentPolicy {
  id                  String    @id @default(cuid())
  agentId             String    @unique
  dailyBudgetUSDC     Float
  remainingBudgetUSDC Float
  maxPurchaseUSDC     Float
  minimumScore        Int       @default(60)
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AgentExecution {
  id                 String    @id @default(cuid())
  agentId            String
  goal               String
  status             String    @default("PLANNING")
  decision           String?
  selectedResourceId String?
  reasoning          Json
  estimatedCostUSDC  Float?
  txHash             String?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
  @@index([selectedResourceId])
  @@index([startedAt])
}
